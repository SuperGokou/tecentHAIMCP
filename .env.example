# ─────────────────────────────────────────────────────────────
# Tencent HAI MCP — example environment configuration
# Copy to .env (for local dev) or paste these into your MCP client's `env` block.
# NEVER commit a real .env — it is gitignored.
# ─────────────────────────────────────────────────────────────

# Tencent Cloud API credentials — create at:
#   https://console.cloud.tencent.com/cam/capi
TENCENTCLOUD_SECRET_ID=your-secret-id
TENCENTCLOUD_SECRET_KEY=your-secret-key

# Default region for HAI instances (e.g. ap-guangzhou, ap-shanghai, ap-singapore)
HAI_REGION=ap-guangzhou

# ── SSH access to your HAI instance (only needed for remote deploy / command tools) ──
# The server logs into the instance on your behalf so you never touch a terminal.
HAI_SSH_USER=ubuntu
HAI_SSH_PORT=22
# Provide ONE of the following:
HAI_SSH_KEY_PATH=
HAI_SSH_PASSWORD=
# Optional: a known_hosts file to verify the instance's SSH host key.
# When unset, new host keys are auto-accepted (convenient for fresh instances).
HAI_SSH_KNOWN_HOSTS=
